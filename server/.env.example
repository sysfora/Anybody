# =============================================================================
# Anybody — Socket.IO / generation server environment
# =============================================================================
# HOW TO USE
#   1. Copy this file to `server/.env`
#   2. Fill in real values (or reuse matching values from the root `.env`)
#   3. Start the server: `npm run dev:ws` (from repo root)
#
# LOADING ORDER (ws_app.py)
#   1) repo root `.env` is loaded first
#   2) `server/.env` is loaded second and overrides root for the same keys
#
# RELATED
#   Frontend env docs: `../.env.example`
#   Frontend must set NEXT_PUBLIC_WS_URL to this server's public URL.
# =============================================================================

# -----------------------------------------------------------------------------
# PocketBase  [REQUIRED for saving chats/HTML + loading AI keys]
# -----------------------------------------------------------------------------
# Origin where PocketBase serves /api/* (no trailing slash).
# Wrong host/path → 404 on admin auth; streaming still works but nothing saves.
POCKETBASE_URL=https://control.anybody.dev
# Local example:
# POCKETBASE_URL=http://127.0.0.1:8090

# Also accepted as a fallback if POCKETBASE_URL is unset:
# NEXT_PUBLIC_POCKETBASE_URL=https://control.anybody.dev

# Same superadmin as root `.env` (server-side only).
POCKETBASE_SUPERADMIN_EMAIL=admin@example.com
POCKETBASE_SUPERADMIN_PASSWORD=your-superadmin-password

# -----------------------------------------------------------------------------
# AI provider keys  [NOT set in this file]
# -----------------------------------------------------------------------------
# Keys are loaded at runtime from PocketBase collection: `api_Keys`
# Supported providers: OpenRouter | OpenAI | Anthropic
# Supported types:     Agent (streaming generation) | Optimizer (prompt polish)
# Configure rows in PocketBase Admin, not via env vars.

# -----------------------------------------------------------------------------
# WebSocket auth  [REQUIRED in production]
# -----------------------------------------------------------------------------
# Must be IDENTICAL to root `.env` → WS_SECRET (not NEXT_PUBLIC_WS_SECRET).
# If unset, auth tokens are not verified (dev-only; insecure for production).
WS_SECRET=generate-a-long-random-secret

# -----------------------------------------------------------------------------
# App URL  [RECOMMENDED]
# -----------------------------------------------------------------------------
# Used as OpenRouter HTTP-Referer and as the default preview base URL.
NEXT_PUBLIC_APP_URL=https://anybody.dev
# Local example:
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: override only for the Playwright preview screenshot worker.
# PREVIEW_APP_URL=https://anybody.dev
# Local example:
# PREVIEW_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Preview screenshot worker (Playwright)  [OPTIONAL]
# -----------------------------------------------------------------------------
# Shared secret when calling a protected Next.js preview-capture endpoint.
PREVIEW_WORKER_SECRET=generate-another-random-secret

# Tuning (defaults shown — leave as-is unless you know you need to change them)
# Max capture attempts per project before giving up
PREVIEW_WORKER_MAX_ATTEMPTS=3
# Sleep between idle polls (seconds)
PREVIEW_WORKER_IDLE_SLEEP_S=2.0
# Wait after page load before screenshot (seconds)
PREVIEW_WORKER_WAIT_FOR_PAINT_S=3.0
# How often to scan for projects needing a preview (seconds)
PREVIEW_WORKER_SCAN_INTERVAL_S=600
# Only capture projects older than this many seconds
PREVIEW_WORKER_MIN_AGE_S=3600

# -----------------------------------------------------------------------------
# Generation tuning  [OPTIONAL]
# -----------------------------------------------------------------------------
# Max modify/patch loops per user edit turn (higher = more repair attempts).
MAX_PATCH_ITERATIONS=5

# =============================================================================
# How to run
# =============================================================================
# From repo root (recommended):
#   npm run dev:ws
#
# Manually:
#   cd server
#   python -m venv .venv
#   .venv\Scripts\activate          # Windows
#   # source .venv/bin/activate     # macOS / Linux
#   pip install -r requirements.txt
#   python -m uvicorn ws_app:app --host 127.0.0.1 --port 5000 --reload
#
# Docker:
#   docker run --env-file server/.env -p 5000:5000 anybody-ws
#
# FRONTEND CHECKLIST
#   Root `.env` must include:
#     NEXT_PUBLIC_WS_URL=http://localhost:5000     (local)
#     NEXT_PUBLIC_WS_URL=https://app.anybody.dev   (production)
#     WS_SECRET=<same value as this file>
#
# QUICK HEALTH CHECK
#   Chat header should not say Offline.
#   Send a message with a project_id → HTML/messages appear in PocketBase.
