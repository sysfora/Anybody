# =============================================================================
# Anybody — Frontend / Next.js environment
# =============================================================================
# HOW TO USE
#   1. Copy this file to `.env` in the repo root
#   2. Replace every placeholder (xxxxxxxx / example.com) with real values
#   3. Restart `npm run dev` after any change
#
# NOTES
#   - Variables prefixed NEXT_PUBLIC_* are exposed to the browser. Never put
#     secret keys (Stripe secret, SMTP pass, WS_SECRET, PocketBase password)
#     in a NEXT_PUBLIC_* variable.
#   - The Socket.IO server also reads root `.env` (then overrides with
#     server/.env). Keep WS_SECRET identical in both places.
#   - See `server/.env.example` for the generation server variables.
# =============================================================================

# -----------------------------------------------------------------------------
# PocketBase  [REQUIRED]
# Auth, users, projects, and admin API routes.
# -----------------------------------------------------------------------------
# Public PocketBase origin (no trailing slash). Must serve /api/*.
NEXT_PUBLIC_POCKETBASE_URL=https://control.anybody.dev
# Local example:
# NEXT_PUBLIC_POCKETBASE_URL=http://127.0.0.1:8090

# Superadmin credentials (server-side only). Used by Next.js API routes and
# the Socket.IO server for privileged PocketBase writes.
POCKETBASE_SUPERADMIN_EMAIL=admin@example.com
POCKETBASE_SUPERADMIN_PASSWORD=your-superadmin-password

# -----------------------------------------------------------------------------
# App URLs  [REQUIRED]
# -----------------------------------------------------------------------------
# Public site URL used for Stripe redirects, emails, metadata, sitemap, etc.
NEXT_PUBLIC_APP_URL=https://anybody.dev
# Local example:
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Socket.IO / generation backend URL (browser connects here).
NEXT_PUBLIC_WS_URL=https://app.anybody.dev
# Local example (must match uvicorn port):
# NEXT_PUBLIC_WS_URL=http://localhost:5000

# Optional explicit HTTP API base (only if different from WS host).
# NEXT_PUBLIC_API_URL=https://app.anybody.dev

# Shared HMAC secret for WebSocket auth tokens.
# MUST match server/.env → WS_SECRET exactly. Never use NEXT_PUBLIC_*.
WS_SECRET=generate-a-long-random-secret

# Optional chat attachment limits (defaults: 5 files, 10 MB each).
# NEXT_PUBLIC_MAX_ATTACHMENTS=5
# NEXT_PUBLIC_MAX_ATTACHMENT_SIZE_MB=10

# -----------------------------------------------------------------------------
# Analytics  [OPTIONAL]
# Loaded only after the user accepts the cookie consent banner.
# -----------------------------------------------------------------------------
# Google Analytics → Admin → Data streams → Measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-01GRXY8SS6

# Microsoft Clarity → Settings → Setup → Project ID
NEXT_PUBLIC_CLARITY_PROJECT_ID=xoh2dqknxr

# -----------------------------------------------------------------------------
# Stripe  [REQUIRED for billing]
# Dashboard: https://dashboard.stripe.com/apikeys
# -----------------------------------------------------------------------------
# Publishable key is safe for the browser (pk_test_... or pk_live_...).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxx

# Secret key is server-only (sk_test_... or sk_live_...). Never commit real keys.
STRIPE_SECRET_KEY=sk_test_xxxxxxxx

# Webhook signing secret (whsec_...). See "Stripe webhook setup" below.
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

# Optional legacy single monthly/yearly price IDs (if still referenced).
# NEXT_PUBLIC_STRIPE_MONTHLY_PRICE_ID=price_xxxxxxxx
# NEXT_PUBLIC_STRIPE_YEARLY_PRICE_ID=price_xxxxxxxx

# Monthly credit-pack Price IDs (Stripe → Products → Price → price_...)
NEXT_PUBLIC_STRIPE_CREDITS_500_PRICE_ID=price_xxxxxxxx
NEXT_PUBLIC_STRIPE_CREDITS_1000_PRICE_ID=price_xxxxxxxx
NEXT_PUBLIC_STRIPE_CREDITS_1500_PRICE_ID=price_xxxxxxxx
NEXT_PUBLIC_STRIPE_CREDITS_2000_PRICE_ID=price_xxxxxxxx
NEXT_PUBLIC_STRIPE_CREDITS_2500_PRICE_ID=price_xxxxxxxx
NEXT_PUBLIC_STRIPE_CREDITS_3000_PRICE_ID=price_xxxxxxxx
NEXT_PUBLIC_STRIPE_CREDITS_3500_PRICE_ID=price_xxxxxxxx
NEXT_PUBLIC_STRIPE_CREDITS_4000_PRICE_ID=price_xxxxxxxx
NEXT_PUBLIC_STRIPE_CREDITS_4500_PRICE_ID=price_xxxxxxxx
NEXT_PUBLIC_STRIPE_CREDITS_5000_PRICE_ID=price_xxxxxxxx

# Yearly credit-pack Price IDs
NEXT_PUBLIC_STRIPE_CREDITS_500_YEARLY_PRICE_ID=price_xxxxxxxx
NEXT_PUBLIC_STRIPE_CREDITS_1000_YEARLY_PRICE_ID=price_xxxxxxxx
NEXT_PUBLIC_STRIPE_CREDITS_1500_YEARLY_PRICE_ID=price_xxxxxxxx
NEXT_PUBLIC_STRIPE_CREDITS_2000_YEARLY_PRICE_ID=price_xxxxxxxx
NEXT_PUBLIC_STRIPE_CREDITS_2500_YEARLY_PRICE_ID=price_xxxxxxxx
NEXT_PUBLIC_STRIPE_CREDITS_3000_YEARLY_PRICE_ID=price_xxxxxxxx
NEXT_PUBLIC_STRIPE_CREDITS_3500_YEARLY_PRICE_ID=price_xxxxxxxx
NEXT_PUBLIC_STRIPE_CREDITS_4000_YEARLY_PRICE_ID=price_xxxxxxxx
NEXT_PUBLIC_STRIPE_CREDITS_4500_YEARLY_PRICE_ID=price_xxxxxxxx
NEXT_PUBLIC_STRIPE_CREDITS_5000_YEARLY_PRICE_ID=price_xxxxxxxx

# -----------------------------------------------------------------------------
# SMTP  [REQUIRED for team invite emails]
# Used by app/api/team/invite. Example below uses Resend.
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
# true = TLS on connect (usually port 465). false = STARTTLS (usually 587).
SMTP_SECURE=false
SMTP_USER=resend
# API key / SMTP password (e.g. Resend re_...)
SMTP_PASS=re_xxxxxxxx
SMTP_FROM_EMAIL=contact@example.com
SMTP_FROM_NAME=Anybody

# =============================================================================
# Stripe webhook setup
# =============================================================================
# WHERE: Stripe Dashboard → Developers → Webhooks → Add endpoint
#
# ENDPOINT URL
#   Production:  {NEXT_PUBLIC_APP_URL}/api/stripe/webhook
#                e.g. https://anybody.dev/api/stripe/webhook
#   Local:       stripe listen --forward-to localhost:3000/api/stripe/webhook
#                Then paste the printed whsec_... into STRIPE_WEBHOOK_SECRET
#
# EVENTS TO SELECT (required by app/api/stripe/webhook/route.ts)
#   - checkout.session.completed
#   - customer.subscription.created
#   - customer.subscription.updated
#   - customer.subscription.deleted
#   - invoice.payment_succeeded
#   - invoice.payment_failed
#   - payment_intent.succeeded
#
# AFTER CREATE
#   Copy the endpoint "Signing secret" (whsec_...) → STRIPE_WEBHOOK_SECRET
#   Use separate secrets for test mode vs live mode.

# =============================================================================
# Google OAuth setup (via PocketBase)
# =============================================================================
# Anybody uses PocketBase's Google provider. Google redirects to PocketBase,
# then PocketBase sends the user back to /login or /register.
#
# 1) Google Cloud Console → APIs & Services → Credentials
#    Create OAuth 2.0 Client ID → Application type: Web application
#
# 2) Authorized JavaScript origins
#    Production:
#      https://anybody.dev
#      https://control.anybody.dev
#    Local:
#      http://localhost:3000
#      http://127.0.0.1:8090
#
# 3) Authorized redirect URIs  ← put THIS in Google Cloud (required)
#    Production:
#      https://control.anybody.dev/api/oauth2-redirect
#    Local PocketBase:
#      http://127.0.0.1:8090/api/oauth2-redirect
#
#    Formula: {NEXT_PUBLIC_POCKETBASE_URL}/api/oauth2-redirect
#
# 4) App pages PocketBase returns to after Google (no Google Console entry needed)
#    Production:  https://anybody.dev/login
#                 https://anybody.dev/register
#    Local:       http://localhost:3000/login
#                 http://localhost:3000/register
#
# 5) PocketBase Admin → Settings → Auth providers → Google
#    Paste Client ID + Client Secret from Google Cloud
#    Enable Google for the `users` collection
#
# IMPORTANT
#   Google Cloud only needs the PocketBase callback (/api/oauth2-redirect).
#   /login and /register are app redirects after PocketBase finishes OAuth.
